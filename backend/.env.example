NODE_ENV=development
PORT=3000
JWT_SECRET=aetherpay-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=aetherpay-refresh-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_KEY=32-char-encryption-key-here-for-aether-pay
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aetherpay_db
DB_USER=postgres
DB_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Recharge API → Ezytm / Robotic Exchange (LAPU-based) ─────────────────────
# Dashboard: https://roboticexchange.in  |  Your Member API Id: 4726
EZYTM_BASE_URL=https://roboticexchange.in
EZYTM_MEMBER_ID=4726
EZYTM_API_PASSWORD=Akash@8285
EZYTM_MOBILE_NO=8744012845

# ── BBPS API → KwikAPI ───────────────────────────────────────────────────────
# Dashboard: https://kwikapi.com  |  Get from Settings → API Credentials
KWIKAPI_BASE_URL=https://api.kwikapi.com/v1
KWIKAPI_CLIENT_ID=your_kwikapi_client_id
KWIKAPI_CLIENT_SECRET=your_kwikapi_client_secret

# ── Payment Gateway → PayU ────────────────────────────────────────────────────
# Dashboard: https://payu.in  |  MID: 12906764  |  Get from Settings → Developer
PAYU_MERCHANT_KEY=your_6char_merchant_key
PAYU_SALT=your_32char_salt
PAYU_MODE=TEST
# Live URL: https://secure.payu.in/_payment
# Test URL: https://test.payu.in/_payment

# ── SMS / OTP → Fast2SMS ──────────────────────────────────────────────────────
# Dashboard: https://fast2sms.com  |  Balance: ₹508.50
# Get API Key from: Dev API section (left sidebar)
# Register DLT Sender ID before going live
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_SENDER_ID=AETHRP
FAST2SMS_OTP_ROUTE=otp
FAST2SMS_SMS_ROUTE=dlt

# ── Firebase FCM (Push Notifications) ────────────────────────────────────────
# Create project at: https://console.firebase.google.com
# Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"aetherpay"}

# ── Cloudinary (KYC Document Uploads) ────────────────────────────────────────
# Free account: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret

# ── SendGrid (Transactional Email) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@aetherpay.in
SENDGRID_FROM_NAME=AetherPay

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=admin-specific-secret-key-for-aetherpay
ADMIN_JWT_EXPIRES_IN=8h
